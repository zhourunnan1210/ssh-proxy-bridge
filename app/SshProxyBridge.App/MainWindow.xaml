<Window x:Class="SshProxyBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SSH Proxy Bridge"
        Width="980" Height="680" MinWidth="820" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei">
    <Grid>
        <Grid x:Name="MainContent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#172033">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="92" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,22,12,18">
                    <Border Width="42" Height="42" CornerRadius="12" Background="#2563EB">
                        <TextBlock Text="S" Foreground="White" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="11,2,0,0">
                        <TextBlock Text="SSH Proxy" Foreground="White" FontWeight="SemiBold" FontSize="15" />
                        <TextBlock Text="Bridge" Foreground="#94A3B8" FontSize="13" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="ServersNavButton" Style="{StaticResource NavButtonStyle}"
                            Background="#26344D" Foreground="White" Click="ShowServers_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="●" FontSize="12" Foreground="#60A5FA" Margin="0,0,12,0" />
                            <TextBlock Text="服务器" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ProductNavButton" Style="{StaticResource NavButtonStyle}"
                            Click="ShowUserGuide_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="14" Margin="0,0,10,0" />
                            <TextBlock Text="使用说明" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="2" Margin="16" Padding="12" CornerRadius="9" Background="#111827">
                    <StackPanel>
                        <TextBlock Text="本机代理" Foreground="#94A3B8" FontSize="11" />
                        <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                            <Ellipse x:Name="ProxyDot" Width="8" Height="8" Fill="#94A3B8" Margin="0,0,8,0" />
                            <TextBlock x:Name="ProxySummaryText" Text="等待检查" Foreground="White" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid x:Name="ServerPage" Grid.Column="1" Margin="32,28,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="我的服务器" FontSize="26" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="建立代理隧道，并直接打开远程项目"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="EditProfileButton" Content="编辑"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="EditProfile_Click" Margin="0,0,8,0" />
                    <Button x:Name="DeleteProfileButton" Content="删除"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="DeleteProfile_Click" Margin="0,0,8,0" />
                    <Button x:Name="AddServerButton" Content="＋ 添加服务器"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="AddServer_Click" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="16" Padding="24">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" BlurRadius="18" ShadowDepth="3" Opacity="0.08" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <ComboBox x:Name="ProfileSelector" MinWidth="280" MaxWidth="440"
                                      HorizontalAlignment="Left" DisplayMemberPath="DisplayName"
                                      FontSize="17" FontWeight="SemiBold" Padding="7,5"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      SelectionChanged="ProfileSelector_SelectionChanged" />
                            <TextBlock x:Name="EndpointText" Text="—"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,7,0,0" />
                        </StackPanel>
                        <Border x:Name="StatusBadge" Grid.Column="1" CornerRadius="14"
                                Background="#F1F5F9" Padding="12,7" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                         Fill="#94A3B8" Margin="0,0,8,0" />
                                <TextBlock x:Name="StatusText" Text="未检查" Foreground="#475569"
                                           FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1" Margin="0,20,0,20" Padding="14,11"
                            Background="#F8FAFC" CornerRadius="9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="远程目录" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock x:Name="WorkspaceText" Grid.Column="1" Text="—"
                                       Margin="18,0,0,0" FontFamily="Microsoft YaHei UI, Microsoft YaHei"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="DiagnosticsButton" Content="运行诊断"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="Diagnostics_Click" Margin="0,0,9,0" />
                        <Button x:Name="StatusButton" Content="刷新状态"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="Status_Click" Margin="0,0,9,0" />
                        <Button x:Name="StopButton" Content="停止连接"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="Stop_Click" Margin="0,0,9,0" />
                        <Button x:Name="ConnectButton" Content="连接并打开 VS Code"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="Connect_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="2,0,2,10">
                    <TextBlock Text="运行信息" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="LastCheckedText" Text=""
                               HorizontalAlignment="Right"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                </Grid>
                <Border Grid.Row="1" Background="#101827" CornerRadius="12" Padding="16">
                    <TextBox x:Name="LogTextBox" Text="界面已就绪。正在检查当前连接状态…"
                             IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                             BorderThickness="0" Background="Transparent" Foreground="#D7E0EE"
                             FontFamily="Microsoft YaHei UI, Microsoft YaHei" FontSize="12" />
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="ProductPage" Grid.Column="1" Margin="32,28,32,24"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <StackPanel>
                    <TextBlock Text="使用说明" FontSize="26" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="从添加服务器到日常连接的完整用户手册"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                </StackPanel>
                <TextBlock x:Name="ProductSourceText" HorizontalAlignment="Right"
                           VerticalAlignment="Bottom" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Grid>

            <Border Grid.Row="2" Background="White"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="14">
                <FlowDocumentScrollViewer x:Name="ProductDocumentViewer"
                                          IsToolBarVisible="True"
                                          VerticalScrollBarVisibility="Auto" />
            </Border>
        </Grid>
        </Grid>

        <Border x:Name="OverlayBackdrop"
                Panel.ZIndex="100" Visibility="Collapsed"
                Background="#590F172A">
            <Grid Margin="16">
                <ContentControl x:Name="OverlayContent"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch" />
            </Grid>
        </Border>
    </Grid>
</Window>
