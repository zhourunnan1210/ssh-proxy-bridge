<UserControl x:Class="SshProxyBridge.App.NoticePanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="540" Height="360"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#172033" Padding="26,21">
            <StackPanel>
                <TextBlock x:Name="TitleText" Foreground="White"
                           FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="SSH Proxy Bridge" Foreground="#AFC0D8"
                           FontSize="12" Margin="0,5,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="26,22" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="MessageText" TextWrapping="Wrap" LineHeight="23"
                       Foreground="{StaticResource TextPrimaryBrush}" />
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="26,0,26,24">
            <Button Content="知道了" Style="{StaticResource PrimaryButtonStyle}"
                    Click="Close_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</UserControl>
